<svg xmlns="http://www.w3.org/2000/svg" width="320" height="88" viewBox="0 0 320 88" role="img" aria-labelledby="title desc">
  <title id="title">すみかみらい 仮ロゴ</title><desc id="desc">正式ロゴに差し替えるための文字プレースホルダー</desc>
  <rect width="320" height="88" fill="#ffffff"/><rect x="1" y="1" width="86" height="86" fill="#17324a"/><text x="44" y="57" text-anchor="middle" font-family="serif" font-size="34" fill="#ffffff">住</text><text x="107" y="43" font-family="sans-serif" font-size="24" font-weight="700" fill="#17324a">すみかみらい</text><text x="108" y="65" font-family="sans-serif" font-size="11" fill="#5e6a71">正式ロゴへ差し替え予定</text>
</svg>

